{
	"name": "@capotej/pi-mise",
	"version": "1.0.0",
	"description": "Automatically activates mise when a mise.toml or .mise.toml file is found in the project",
	"keywords": ["pi-package", "mise"],
	"license": "MIT",
	"author": "Julio Capote <6135+capotej@users.noreply.github.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/capotej/pi-mise.git"
	},
	"files": ["extensions", "skills", "README.md", "LICENSE"],
	"pi": {
		"extensions": ["./extensions"],
		"skills": ["./skills"]
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"packageManager": "pnpm@10.33.2",
	"publishConfig": {
		"access": "public"
	}
}
