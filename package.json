{
	"name": "@capotej/pi-mise",
	"version": "1.0.1",
	"type": "module",
	"description": "Automatically activates mise when a mise.toml or .mise.toml file is found in the project",
	"keywords": ["pi-package", "mise"],
	"license": "MIT",
	"author": "Julio Capote <6135+capotej@users.noreply.github.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/capotej/pi-mise.git"
	},
	"files": ["dist", "skills", "README.md", "LICENSE"],
	"pi": {
		"extensions": ["./dist/extensions/mise.js"],
		"skills": ["./skills"]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@mariozechner/pi-coding-agent": "^0.73.1",
		"@types/node": "^22.0.0",
		"typescript": "^6.0.2"
	},
	"scripts": {
		"build": "tsc",
		"prepare": "tsc",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"packageManager": "pnpm@10.33.2",
	"publishConfig": {
		"access": "public"
	}
}
